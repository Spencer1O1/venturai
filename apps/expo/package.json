{
  "name": "@venturai/expo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "eas-build-pre-install": "corepack enable",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --profile preview --platform android --clear-cache",
    "build:ios": "eas build --profile preview --platform ios --local",
    "clean": "git clean -xdf .expo .cache .turbo node_modules",
    "dev": "expo start",
    "format": "biome check . --linter-enabled=false --fix",
    "lint": "biome lint . --write",
    "postinstall": "node ../../scripts/symlink-env.js",
    "prebuild": "expo prebuild",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@venturai/backend": "workspace:*",
    "convex": "^1.32.0",
    "expo": "^55.0.4",
    "expo-build-properties": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.10",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@venturai/typescript": "workspace:*",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3"
  },
  "main": "expo-router/entry"
}
