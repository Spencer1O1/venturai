# Convex deployment URL (same value for all; get it from `pnpm dev:backend` or Convex dashboard)
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_URL=

# App base URL (for NFC tag deep links, invite links). Default: https://venturai.app
EXPO_PUBLIC_APP_URL=https://venturai.app

# Environment
APP_ENV=development

# Mapbox (optional, for map features)
RNMAPBOX_ACCESS_TOKEN=
RNMAPBOX_DOWNLOAD_TOKEN=
